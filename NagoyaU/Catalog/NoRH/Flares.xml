         <AccessURL>
            <URL>https://solar.nro.nao.ac.jp/norh/html/event/</URL>
         </AccessURL>
         <Format>HTML</Format>
      </AccessInformation>
      <InstrumentID>spase://SMWG/Instrument/NOB_RH/NORH</InstrumentID>
